{
  "name": "tiwa",
  "version": "0.1.0",
  "private": true,
  "description": "Tiwa (\u0e17\u0e34\u0e27\u0e32) - AI Orchestrator System",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "docker:dev": "docker compose --env-file .env -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose --env-file .env -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose --env-file .env -f docker-compose.dev.yml logs -f",
    "docker:prod": "docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose --env-file .env.prod -f docker-compose.prod.yml down",
    "db:generate": "pnpm --filter backend prisma generate",
    "db:migrate": "pnpm --filter backend prisma migrate dev",
    "db:push": "pnpm --filter backend prisma db push",
    "db:studio": "pnpm --filter backend prisma studio",
    "cli:build": "pnpm --filter @w3pep/tiwa build",
    "cli:dev": "pnpm --filter @w3pep/tiwa dev"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "protobufjs",
      "cpu-features",
      "ssh2",
      "msgpackr-extract",
      "unrs-resolver",
      "@nestjs/core"
    ]
  }
}
