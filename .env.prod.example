# ============================================
# Tiwa - Production Environment Variables
# ============================================

NODE_ENV=production

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=tiwa
POSTGRES_PASSWORD=<GENERATE_STRONG_PASSWORD>
POSTGRES_DB=tiwa
DATABASE_URL=postgresql://tiwa:<GENERATE_STRONG_PASSWORD>@postgres:5432/tiwa?schema=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<GENERATE_STRONG_PASSWORD>

# --- MongoDB ---
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=tiwa
MONGO_PASSWORD=<GENERATE_STRONG_PASSWORD>
MONGO_DB=tiwa
MONGO_URI=mongodb://tiwa:<GENERATE_STRONG_PASSWORD>@mongodb:27017/tiwa?authSource=admin

# --- Backend ---
BACKEND_PORT=4000
JWT_SECRET=<GENERATE_STRONG_SECRET>
JWT_EXPIRATION=1d

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# --- Worker ---
WORKER_CONCURRENCY=5

# --- GitHub ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI / LLM ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=gpt-4o
