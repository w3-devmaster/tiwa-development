{
  "name": "@w3pep/tiwa",
  "version": "0.1.0",
  "description": "Tiwa CLI - Command line interface for Tiwa AI Orchestrator",
  "type": "module",
  "bin": {
    "tiwa": "./bin/run.js"
  },
  "main": "dist/index.js",
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "node --loader ts-node/esm bin/dev.js",
    "prepack": "npm run build",
    "postinstall": "[ -d dist ] || npm run build 2>/dev/null || true"
  },
  "dependencies": {
    "@oclif/core": "^4.2.0",
    "execa": "^9.5.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tiwa/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "oclif": {
    "bin": "tiwa",
    "dirname": "tiwa",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "topicSeparator": " "
  },
  "engines": {
    "node": ">=20"
  }
}
