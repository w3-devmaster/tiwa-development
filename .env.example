# ============================================
# Tiwa - Development Environment Variables
# ============================================

# --- General ---
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tiwa
POSTGRES_PASSWORD=tiwa_dev_password
POSTGRES_DB=tiwa

# Prisma connection string
DATABASE_URL=postgresql://tiwa:tiwa_dev_password@localhost:5432/tiwa?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MongoDB ---
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=tiwa
MONGO_PASSWORD=tiwa_dev_password
MONGO_DB=tiwa
MONGO_URI=mongodb://tiwa:tiwa_dev_password@localhost:27017/tiwa?authSource=admin

# --- Backend (NestJS) ---
BACKEND_PORT=4000
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRATION=7d

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# --- Worker ---
WORKER_CONCURRENCY=3

# --- GitHub Integration ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI / LLM ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=gpt-4o
